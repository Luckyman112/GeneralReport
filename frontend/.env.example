# Адрес бэкенда COLLAPSAR Report System
VITE_API_BASE_URL=http://127.0.0.1:8000

# Discord OAuth2 — те же данные, что и в бэкенде (.env DISCORD_CLIENT_ID),
# но здесь это публичные значения, попадающие в собранный бандл — это нормально,
# Client ID не секретен, а redirect_uri должен совпадать с зарегистрированным в Discord
# ВАЖНО: без хэша (#...) — Discord дописывает ?code=... как query-параметр к этому URL,
# а после # браузер интерпретирует всё как фрагмент, а не query. Поэтому редирект — на
# "голый" базовый адрес сайта (тот же, что указан как base в vite.config.js), а разбор
# ?code= происходит на верхнем уровне приложения ещё до того, как HashRouter возьмёт
# на себя маршрутизацию.
VITE_DISCORD_CLIENT_ID=
VITE_DISCORD_REDIRECT_URI=https://your-org.github.io/collapsar-reports/
