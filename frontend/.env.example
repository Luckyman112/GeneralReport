# Self-host: фронт раздаётся тем же процессом FastAPI (см. app/main.py), поэтому
# VITE_API_BASE_URL можно оставить пустым — запросы идут на тот же адрес (same-origin).
VITE_API_BASE_URL=

# Discord OAuth2 Client ID — не секретен, безопасно попадает в собранный бандл.
# redirect_uri вычисляется во время выполнения от текущего адреса (window.location),
# отдельной переменной для него не нужно — но сам адрес всё равно нужно один раз
# вручную зарегистрировать в Discord Developer Portal (OAuth2 -> Redirects).
VITE_DISCORD_CLIENT_ID=
