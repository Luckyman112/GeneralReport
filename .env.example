# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/collapsar

# Discord OAuth2 (Discord Developer Portal -> OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Redirect URI больше не задаётся тут — фронт присылает его сам вместе с code
# (см. AuthContext.jsx), backend просто использует то же значение при обмене кода.
# В Discord Developer Portal всё равно нужно вручную зарегистрировать актуальный адрес.

# Discord Bot (для проверки ролей участников и управления формированиями через REST API)
DISCORD_BOT_TOKEN=
# Единственный Discord-сервер, на котором стоит бот — все формирования различаются
# ролями внутри этого одного сервера
DISCORD_GUILD_ID=

# Роль администратора — видит рапорты всех формирований
ADMIN_ROLE_ID=
# Общая роль «Командир»: командир формирования = эта роль + явное назначение
# командиром конкретного формирования (в веб-панели)
COMMANDER_ROLE_ID=

# Секрет для входа по паролю (в обход Discord), даёт полный админский доступ.
# Держите в секрете, используйте длинную случайную строку.
ADMIN_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS — через запятую. При self-host фронта на том же адресе, что и бэкенд,
# обычно не требуется (same-origin).
ALLOWED_ORIGINS=

LOG_LEVEL=INFO
